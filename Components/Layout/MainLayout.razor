@inherits LayoutComponentBase
@inject NavigationManager NavManager
@using StreetTshirtApp.Models


<div class="page d-flex flex-column min-vh-100">
    <main class="flex-grow-1">
        <NavMenu />

        <div class="container mt-3">
            
            @if (NavManager.ToBaseRelativePath(NavManager.Uri).Split('?')[0] != "")
            {
                <Breadcrumbs Items="GetBreadcrumbs()" />
            }

            <article>
                @Body
            </article>
        </div>
    </main>

    
    <Footer />
</div>

@code {
    private List<BreadcrumbItem> GetBreadcrumbs()
    {
       
        var fullRelativeUri = NavManager.ToBaseRelativePath(NavManager.Uri);
        var cleanUri = fullRelativeUri.Split('?')[0]; 

        // 2. Criamos os segmentos baseados na URI limpa
        var segments = cleanUri.Split('/', StringSplitOptions.RemoveEmptyEntries);
        
        var items = new List<BreadcrumbItem>
        {
            new BreadcrumbItem { Text = "HOME", Url = "/" }
        };

        var accumulatedPath = "";

        for (int i = 0; i < segments.Length; i++)
        {
            var segment = segments[i];
            accumulatedPath += $"/{segment}";
            
            // Ignora IDs numéricos no breadcrumb para manter o visual limpo
            if (int.TryParse(segment, out _)) continue;

            items.Add(new BreadcrumbItem
            {
                Text = segment.ToUpper(),
                Url = accumulatedPath,
                IsActive = (i == segments.Length - 1)
            });
        }

        return items;
    }

    protected override void OnInitialized()
    {
        
        NavManager.LocationChanged += (s, e) => StateHasChanged();
    }
}