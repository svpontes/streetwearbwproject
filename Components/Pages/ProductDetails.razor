@page "/product/{id:int}"
@rendermode InteractiveServer
@using StreetTshirtApp.Models
@implements IDisposable
@inject StreetTshirtApp.Services.CartService CartService

<PageTitle>@(product?.Name ?? "Product Details") - BluntWear</PageTitle>

@if (product == null)
{
    <div class="text-center mt-5">
        <p class="lead">Loading...</p>
    </div>
}
else
{
    <div class="container mt-4 mb-5">
        @* --- BREADCRUMB IMPLEMENTADO AQUI --- *@
        <Breadcrumbs Items="breadcrumbItems" />
        @* ------------------------------------ *@

        <div class="row align-items-start mt-4">
            
            @* Seção de Imagens *@
            <div class="col-md-6 mb-4 mb-md-0">
                <div class="p-5 text-center rounded-3 border-0 mb-3" style="background-color: #f8f9fa;">
                    <img src="@currentMainImageUrl" alt="@product.Name" class="img-fluid" style="max-height: 500px; object-fit: contain; transition: opacity 0.3s;" />
                </div>

                <div class="row g-2">
                    <div class="col-3">
                        <img src="@product.ImageUrl" alt="Main view" 
                             class="img-thumbnail @(currentMainImageUrl == product.ImageUrl ? "border-dark border-2" : "border-0")" 
                             style="cursor: pointer; background-color: #f8f9fa; aspect-ratio: 1/1; object-fit: contain;" 
                             @onclick="() => ChangeMainImage(product.ImageUrl)" />
                    </div>

                    @foreach (var imageUrl in product.SecondaryImageUrls)
                    {
                        <div class="col-3">
                            <img src="@imageUrl" alt="Additional view" 
                                 class="img-thumbnail @(currentMainImageUrl == imageUrl ? "border-dark border-2" : "border-0")" 
                                 style="cursor: pointer; background-color: #f8f9fa; aspect-ratio: 1/1; object-fit: contain;" 
                                 @onclick="() => ChangeMainImage(imageUrl)" />
                        </div>
                    }
                </div>
            </div>

            @* Seção de Detalhes *@
            <div class="col-md-6 ps-md-5 text-dark">
                <h2 class="display-5 fw-bold mb-2">@product.Name</h2>
                
                @* Cálculo dinâmico de subtotal na tela *@
                <h4 class="fw-bold mb-4" style="color: #5f5e5e;">$@((product.Price * quantity).ToString("F2"))</h4>
                
                <p class="lead mb-4 text-muted">@product.Description</p>

                @* Seleção de Tamanho *@
                <div class="mb-4">
                    <h5 class="fw-bold mb-3 @(showSizeWarning ? "text-danger" : "")">
                        Choose Size: @(showSizeWarning ? " (Required)" : "")
                    </h5>
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var size in product.AvailableSizes)
                        {
                            <button class="btn @(selectedSize == size ? "btn-dark" : "btn-outline-dark") px-4 py-2 fw-bold" 
                                    @onclick="() => SelectSize(size)">
                                @size
                            </button>
                        }
                    </div>
                </div>

                @* Quantidade *@
                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Quantity:</h5>
                    <div class="input-group" style="width: 140px;">
                        <button class="btn btn-outline-dark fw-bold" type="button" @onclick="DecreaseQuantity">-</button>
                        <input type="text" class="form-control text-center fw-bold border-dark bg-white" value="@quantity" readonly />
                        <button class="btn btn-outline-dark fw-bold" type="button" @onclick="IncreaseQuantity">+</button>
                    </div>
                </div>

                @* Botão de Ação *@
                @if (showSuccessMessage)
                {
                    <div class="alert alert-dark text-center fw-bold py-3 mb-0">
                        ✓ ADDED TO CART
                    </div>
                }
                else
                {
                    <button class="btn btn-dark btn-lg w-100 fw-bold py-3 mt-3 shadow-sm" 
                            @onclick="AddToCart">
                        ADD TO CART
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Product? product;
    private string selectedSize = "";
    private bool showSizeWarning = false;
    private bool showSuccessMessage = false;
    private string currentMainImageUrl = string.Empty;
    private int quantity = 1;
    
    // Lista para o Breadcrumb
    private List<BreadcrumbItem> breadcrumbItems = new();

    protected override void OnInitialized()
    {
        product = MockData.GetMockProducts().FirstOrDefault(p => p.Id == Id);
        if (product != null)
        {
            currentMainImageUrl = product.ImageUrl;
            
            // Inicializa a trilha de navegação
            breadcrumbItems = new List<BreadcrumbItem>
            {
                new BreadcrumbItem { Text = "HOME", Url = "/" },
                new BreadcrumbItem { Text = "CATALOG", Url = "/catalog" },
                new BreadcrumbItem { Text = product.Name.ToUpper(), IsActive = true }
            };
        }

        CartService.OnChange += HandleCartChanged;
    }

    private async void HandleCartChanged() 
    {
        await InvokeAsync(StateHasChanged);
    }

    private void ChangeMainImage(string url) => currentMainImageUrl = url;

    private void SelectSize(string size)
    {
        selectedSize = size;
        showSizeWarning = false;
        showSuccessMessage = false;
    }

    private void IncreaseQuantity()
    {
        if (quantity < 10) { quantity++; showSuccessMessage = false; }
    }

    private void DecreaseQuantity()
    {
        if (quantity > 1) { quantity--; showSuccessMessage = false; }
    }
    
    private async Task AddToCart()
    {
        if (string.IsNullOrEmpty(selectedSize))
        {
            showSizeWarning = true;
            return;
        }

        CartService.AddToCart(product!, selectedSize, quantity);
        
        showSuccessMessage = true;
        StateHasChanged(); 

        await Task.Delay(1000);

        showSuccessMessage = false;
        StateHasChanged(); 
    }

    public void Dispose()
    {
        CartService.OnChange -= HandleCartChanged;
    }
}