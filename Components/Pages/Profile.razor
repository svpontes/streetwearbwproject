@page "/profile-old"
@inject StreetTshirtApp.Services.AuthService AuthService
@inject NavigationManager NavManager

<PageTitle>My Profile - BluntWear</PageTitle>

@if (AuthService.CurrentUser == null)
{
    <div class="container text-center mt-5">
        <p class="lead">Please login to view your profile.</p>
        <a href="/login" class="btn btn-dark rounded-0">GO TO LOGIN</a>
    </div>
}
else
{
    <div class="container mt-5 mb-5">
        <div class="row">
            @* Coluna da Esquerda: Dados do Usuário *@
            <div class="col-md-4 mb-4">
                <div class="card bg-black text-white rounded-0 border-0 p-4 shadow">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-circle display-1"></i>
                    </div>
                    <h3 class="fw-bold text-center mb-1">@AuthService.CurrentUser.Name</h3>
                    <p class="text-secondary text-center small mb-4">@AuthService.CurrentUser.Email</p>
                    
                    <hr class="border-secondary" />
                    
                    <button class="btn btn-outline-danger btn-sm w-100 rounded-0 fw-bold" @onclick="Logout">
                        LOGOUT
                    </button>
                </div>
            </div>

            @* Coluna da Direita: Histórico de Pedidos *@
            <div class="col-md-8">
                <h2 class="fw-bold mb-4" style="letter-spacing: 2px;">ORDER HISTORY</h2>
                
                @if (AuthService.CurrentUser.OrderHistory == null || !AuthService.CurrentUser.OrderHistory.Any())
                {
                    <div class="p-5 border border-secondary text-center">
                        <p class="text-muted m-0">You haven't placed any orders yet.</p>
                        <a href="/catalog" class="btn btn-link text-dark fw-bold mt-2">SHOP NOW</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover border">
                            <thead class="table-dark">
                                <tr>
                                    <th class="small">ORDER ID</th>
                                    <th class="small">DATE</th>
                                    <th class="small">TOTAL</th>
                                    <th class="small">STATUS</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in AuthService.CurrentUser.OrderHistory)
                                {
                                    <tr>
                                        <td class="fw-bold">#@order.Id.ToString("D5")</td>
                                        <td class="small">@order.OrderDate.ToShortDateString()</td>
                                        <td class="fw-bold">$@order.TotalAmount.ToString("F2")</td>
                                        <td>
                                            <span class="badge bg-dark rounded-0 px-3">@order.Status.ToUpper()</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private void Logout()
    {
        AuthService.Logout();
        NavManager.NavigateTo("/");
    }
}