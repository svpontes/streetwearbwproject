@using StreetTshirtApp.Models
@inject ApplicationDbContext DbContext

@page "/contact"
@using System.ComponentModel.DataAnnotations
@inject NavigationManager NavManager

<div class="container mt-5 pt-5 pb-5">
    <div class="row g-5">
        <div class="col-lg-4">
            <h2 class="fw-bold text-uppercase mb-4" style="letter-spacing: 3px;">Get in Touch</h2>
            <p class="text-secondary mb-5">Have a question about a drop or a custom PNG art? Drop us a line.</p>
            
            <div class="mb-4">
                <h6 class="fw-bold text-uppercase">Email</h6>
                <p class="text-dark">support@streetwearbw.com</p>
            </div>
            
            <div class="mb-4">
                <h6 class="fw-bold text-uppercase">Studio Address</h6>
                <p class="text-secondary small">123 Streetwear Ave, Digital City<br />Available 24/7 Online</p>
            </div>

            <div class="d-flex gap-3 mt-4">
                <a href="#" class="text-dark fs-4"><i class="bi bi-instagram"></i></a>
                <a href="#" class="text-dark fs-4"><i class="bi bi-twitter-x"></i></a>
                <a href="#" class="text-dark fs-4"><i class="bi bi-tiktok"></i></a>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-0 p-4 p-md-5">
                <EditForm Model="@contactModel" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-uppercase small">Your Name</label>
                            <InputText class="form-control rounded-0 border-dark-subtle py-2" @bind-Value="contactModel.Name" placeholder="Full Name" />
                            <ValidationMessage For="@(() => contactModel.Name)" class="text-danger small" />
                        </div>
                        
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-uppercase small">Email Address</label>
                            <InputText class="form-control rounded-0 border-dark-subtle py-2" @bind-Value="contactModel.Email" placeholder="email@example.com" />
                            <ValidationMessage For="@(() => contactModel.Email)" class="text-danger small" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-uppercase small">Subject</label>
                        <InputSelect class="form-select rounded-0 border-dark-subtle py-2" @bind-Value="contactModel.Subject">
                            <option value="">Select a topic...</option>
                            <option value="Order Status">Order Status</option>
                            <option value="PNG Arts">PNG Arts Support</option>
                            <option value="Collaboration">Collaboration</option>
                            <option value="Other">Other</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => contactModel.Subject)" class="text-danger small" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-uppercase small">Message</label>
                        <InputTextArea class="form-control rounded-0 border-dark-subtle" rows="5" @bind-Value="contactModel.Message" placeholder="How can we help you?" />
                        <ValidationMessage For="@(() => contactModel.Message)" class="text-danger small" />
                    </div>

                    @if (showSuccessMessage)
                    {
                        <div class="alert alert-dark rounded-0 mb-4 animate__animated animate__fadeIn">
                            <i class="bi bi-check2-all me-2"></i> Message sent! We'll get back to you soon.
                        </div>
                    }

                    <button type="submit" class="btn btn-dark w-100 py-3 fw-bold text-uppercase rounded-0 transition-hover">
                        Send Message
                    </button>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private ContactForm contactModel = new();
    private bool showSuccessMessage = false;

    private async Task HandleSubmit()
{
    try 
    {
        // 1. Criamos o objeto de banco a partir dos dados do formulário
        var newMessage = new ContactMessage 
        {
            Name = contactModel.Name,
            Email = contactModel.Email,
            Subject = contactModel.Subject,
            Message = contactModel.Message,
            CreatedAt = DateTime.Now // Registro crucial para fins jurídicos
        };

        // 2. Adicionamos ao contexto e salvamos no arquivo .db
        DbContext.ContactMessages.Add(newMessage);
        await DbContext.SaveChangesAsync();

        // 3. Feedback visual de sucesso
        showSuccessMessage = true;
        contactModel = new(); // Limpa o formulário após enviar
    }
    catch (Exception ex)
    {
        // Log de erro caso algo falhe no banco
        Console.WriteLine($"Error saving message: {ex.Message}");
    }

    StateHasChanged();

    // Esconde a mensagem de sucesso após 5 segundos
    await Task.Delay(5000);
    showSuccessMessage = false;
    StateHasChanged();
}

    public class ContactForm
    {
        [Required(ErrorMessage = "Please tell us your name.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email format.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please select a subject.")]
        public string Subject { get; set; } = string.Empty;

        [Required(ErrorMessage = "The message cannot be empty.")]
        [StringLength(1000, MinimumLength = 10, ErrorMessage = "Message must be between 10 and 1000 characters.")]
        public string Message { get; set; } = string.Empty;

        public DateTime CreatedAt { get; set; } = DateTime.UtcNow;
        public string? UserIp { get; set; }
    }
}

<style>
    .form-control:focus, .form-select:focus {
        border-color: #000;
        box-shadow: none;
    }

    .transition-hover:hover {
        background-color: #333;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }
</style>