@page "/forgot-password"
@inject NavigationManager NavManager
@inject StreetTshirtApp.Data.ApplicationDbContext DbContext
@using Microsoft.EntityFrameworkCore

<div class="row justify-content-center align-items-center min-vh-100" style="margin-top: -100px;">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg p-4 bg-black text-white rounded-0">
            <h2 class="text-white text-center fw-bold mb-4" style="letter-spacing: 2px;">RECOVER ACCESS</h2>
            <p class="text-white text-secondary small text-center mb-4 text-uppercase">Enter your email to receive recovery instructions.</p>

            <div class="mb-4">
                <label class="text-white small fw-bold text-secondary">EMAIL ADDRESS</label>
                <input type="email" @bind="email" class="form-control bg-transparent border-secondary text-white rounded-0 py-2" placeholder="email@example.com" />
            </div>

            @if (!string.IsNullOrEmpty(statusMessage))
            {
                <div class="alert @(isError ? "alert-danger" : "alert-success") bg-transparent border-@(isError ? "danger" : "success") text-@(isError ? "danger" : "lime") small rounded-0 mb-3">
                    @statusMessage
                </div>
            }

            <button class="btn btn-light w-100 fw-bold py-2 mb-3" @onclick="HandleRecovery" disabled="@isProcessing">
                @(isProcessing ? "SENDING..." : "SEND RECOVERY EMAIL")
            </button>

            <div class="text-center">
                <a href="/login" class="text-secondary small text-decoration-none hover-white">Back to Login</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string statusMessage = "";
    private bool isError = false;
    private bool isProcessing = false;

    private async Task HandleRecovery()
    {
        if (string.IsNullOrEmpty(email)) {
            statusMessage = "Please enter your email.";
            isError = true;
            return;
        }

        isProcessing = true;
        isError = false;

        // Simulate database check and email sending
        var userExists = await DbContext.Users.AnyAsync(u => u.Email == email);
        
        await Task.Delay(1500); // Simulate network latency

        if (userExists)
        {
            statusMessage = "Recovery instructions sent! Please check your inbox.";
            isError = false;
        }
        else
        {
            // Security Tip: Even if user doesn't exist, sometimes it's better to show the same message 
            // to prevent "Email Enumeration" attacks.
            statusMessage = "If this email is registered, you will receive a link shortly.";
            isError = false;
        }

        isProcessing = false;
    }
}