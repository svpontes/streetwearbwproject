@page "/checkout"
@using System.ComponentModel.DataAnnotations
@using StreetTshirtApp.Services
@using StreetTshirtApp.Models
@using System.Text.Json

@inject CartService CartService
@inject NavigationManager NavManager
@inject ApplicationDbContext DbContext
@inject AuthService AuthService

<div class="container mt-5 pt-5 pb-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb small text-uppercase">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted">Home</a></li>
            <li class="breadcrumb-item active text-dark fw-bold" aria-current="page">Checkout</li>
        </ol>
    </nav>

    @if (CartService.CartItems.Any())
    {
        
        <div class="row g-4">
            <div class="col-lg-7">
                <div class="bg-dark text-white p-3 mb-4">
                    <h3 class="h4 mb-0 text-uppercase fw-bold text-center" style="letter-spacing: 2px;">Checkout</h3>
                </div>

                <div class="p-2">
                    <h5 class="fw-bold mb-4">Billing Details</h5>

                    <EditForm Model="@checkoutModel" OnValidSubmit="HandleCheckout">
                        <DataAnnotationsValidator />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">First Name</label>
                                <InputText class="form-control rounded-0" @bind-Value="checkoutModel.FirstName" />
                                <ValidationMessage For="@(() => checkoutModel.FirstName)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Last Name</label>
                                <InputText class="form-control rounded-0" @bind-Value="checkoutModel.LastName" />
                                <ValidationMessage For="@(() => checkoutModel.LastName)" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <InputText class="form-control rounded-0" @bind-Value="checkoutModel.Email" />
                            <ValidationMessage For="@(() => checkoutModel.Email)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Phone</label>
                            <InputText class="form-control rounded-0" @bind-Value="checkoutModel.Phone" />
                            <ValidationMessage For="@(() => checkoutModel.Phone)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Address</label>
                            <InputText class="form-control rounded-0" @bind-Value="checkoutModel.Address" />
                            <ValidationMessage For="@(() => checkoutModel.Address)" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">City</label>
                                <InputText class="form-control rounded-0" @bind-Value="checkoutModel.City" />
                                <ValidationMessage For="@(() => checkoutModel.City)" />
                            </div>

                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-bold">Postal Code</label>
                                <InputText class="form-control rounded-0" @bind-Value="checkoutModel.PostalCode" />
                                <ValidationMessage For="@(() => checkoutModel.PostalCode)" />
                            </div>

                            <div class="col-md-3 mb-3">
                                <label class="form-label fw-bold">Country</label>
                                <InputText class="form-control rounded-0" @bind-Value="checkoutModel.Country" />
                                <ValidationMessage For="@(() => checkoutModel.Country)" />
                            </div>
                        </div>

                        <h5 class="fw-bold mt-4 mb-3 text-uppercase">Payment</h5>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Card Number</label>
                            <InputText class="form-control rounded-0" @bind-Value="checkoutModel.CardNumber" />
                            <ValidationMessage For="@(() => checkoutModel.CardNumber)" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Expiry Date</label>
                                <InputText class="form-control rounded-0" @bind-Value="checkoutModel.ExpiryDate" placeholder="MM/YY" />
                                <ValidationMessage For="@(() => checkoutModel.ExpiryDate)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">CVV</label>
                                <InputText class="form-control rounded-0" @bind-Value="checkoutModel.CVV" />
                                <ValidationMessage For="@(() => checkoutModel.CVV)" />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-3 fw-bold text-uppercase rounded-0 mt-3">
                            Place Order
                        </button>
                    </EditForm>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="bg-dark text-white p-3 mb-0">
                    <h4 class="h5 mb-0 text-uppercase fw-bold" style="letter-spacing: 1px;">Order Summary</h4>
                </div>
                
                <div class="card p-4 bg-white border border-secondary-subtle rounded-0 shadow-sm sticky-top" style="top: 100px; z-index: 1000;">
                    <h4 class="fw-bold mb-4">Order Summary</h4>

                    @foreach (var item in CartService.CartItems)
                    {
                        <div class="d-flex align-items-center mb-3 border-bottom pb-3">
                            
                            <div class="me-3" style="width: 60px; height: 60px; background-color: #fff;">
                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name" 
                                    class="img-fluid" style="object-fit: cover; width: 100%; height: 100%;" />
                            </div>

                            <div class="flex-grow-1">
                                
                                <h6 class="fw-bold mb-0">
                                    <a href="/product/@item.Product.Id" target="_blank" class="text-black text-decoration-none text-uppercase" style="font-size: 0.9rem;">
                                        @item.Product.Name <i class="bi bi-box-arrow-up-right ms-1" style="font-size: 0.7rem;"></i>
                                    </a>
                                </h6>
                                <small class="text-secondary text-uppercase" style="font-size: 0.7rem;">
                                    SIZE: @item.Size | QTY: @item.Quantity
                                </small>
                            </div>

                            <div class="text-end">
                                <span class="fw-bold" style="font-size: 0.9rem;">
                                    @((item.Product.Price * item.Quantity).ToString("C"))
                                </span>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-between mb-2 small text-uppercase">
                        <span>Subtotal</span>
                        <span>@CartService.TotalPrice.ToString("C")</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2 small text-uppercase">
                        <span>Shipping</span>
                        <span class="text-success fw-bold">FREE</span>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <span class="h5 fw-bold text-uppercase">Total</span>
                        <span class="h5 fw-bold">@CartService.TotalPrice.ToString("C")</span>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* Carrinho vazio *@
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-secondary"></i>
            <h3 class="mt-4 fw-bold">No items to checkout.</h3>
            <a href="/catalog" class="btn btn-dark px-5 py-3 mt-3 rounded-0 fw-bold">GO TO CATALOG</a>
        </div>
    }
</div>

@code {
    private CheckoutModel checkoutModel = new();

    
    protected override void OnInitialized()
    {
        if (AuthService.CurrentUser != null)
        {
            var user = AuthService.CurrentUser;
            
            // Tentamos separar o nome completo para First/Last Name se possível
            var names = user.Name.Split(' ');
            checkoutModel.FirstName = names.Length > 0 ? names[0] : "";
            checkoutModel.LastName = names.Length > 1 ? string.Join(" ", names.Skip(1)) : "";
            
            // Preenchimento automático dos dados do perfil
            checkoutModel.Email = user.Email;
            checkoutModel.Phone = user.Phone ?? "";
            checkoutModel.Address = user.Address ?? "";
            checkoutModel.City = user.City ?? "";
            checkoutModel.PostalCode = user.ZipCode ?? "";
            checkoutModel.Country = user.Country ?? ""; // Certifique-se que Country existe no seu Model User
        }
    }

   private async Task HandleCheckout()
{
    try 
    {
        // 1. Crie a lista usando a classe OrderItem (que possui a ImageUrl)
        var orderItems = CartService.CartItems.Select(i => new OrderItem 
        {
            ProductId = i.Product.Id,
            ProductName = i.Product.Name,
            ImageUrl = i.Product.ImageUrl, // AGORA A IMAGEM SERÁ SALVA!
            Size = i.Size,
            Quantity = i.Quantity,
            Price = i.Product.Price
        }).ToList();

        var newOrder = new Order
        {
            CustomerName = $"{checkoutModel.FirstName} {checkoutModel.LastName}",
            CustomerEmail = checkoutModel.Email,
            ShippingAddress = $"{checkoutModel.Address}, {checkoutModel.City}, {checkoutModel.Country} - {checkoutModel.PostalCode}",
            TotalAmount = CartService.TotalPrice,
            OrderDate = DateTime.Now,
            Status = "Processing",
            
            
        };

        newOrder.OrderItems = orderItems;
        
        DbContext.Orders.Add(newOrder);
        await DbContext.SaveChangesAsync();

        // 3. Atualize o histórico do usuário na memória para refletir no Perfil imediatamente
        if (AuthService.CurrentUser != null)
        {
            AuthService.CurrentUser.OrderHistory.Add(newOrder);
        }

        CartService.ClearCart();
        NavManager.NavigateTo("/order-success");
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Erro ao processar checkout: {ex.Message}");
    }
}

    public class CheckoutModel
    {
        [Required(ErrorMessage = "First name is required.")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required.")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Invalid email.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Phone is required.")]
        public string Phone { get; set; } = string.Empty;

        [Required(ErrorMessage = "Address is required.")]
        public string Address { get; set; } = string.Empty;

        [Required(ErrorMessage = "City is required.")]
        public string City { get; set; } = string.Empty;

        [Required(ErrorMessage = "Postal code is required.")]
        public string PostalCode { get; set; } = string.Empty;

        [Required(ErrorMessage = "Country is required.")]
        public string Country { get; set; } = string.Empty;

        [Required(ErrorMessage = "Card number is required.")]
        public string CardNumber { get; set; } = string.Empty;

        [Required(ErrorMessage = "Expiry date is required.")]
        public string ExpiryDate { get; set; } = string.Empty;

        [Required(ErrorMessage = "CVV is required.")]
        public string CVV { get; set; } = string.Empty;
    }
}