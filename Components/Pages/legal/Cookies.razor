@page "/cookies"

<div class="container mt-5 pt-5 pb-5">
    <h1 class="fw-bold text-uppercase mb-5" style="letter-spacing: 3px; font-size: 1.5rem;">Cookies Policy</h1>
    
    <div class="row">
        <div class="col-lg-10 text-secondary">
            <p>BluntWear uses cookies to improve your shopping experience and analyze our traffic.</p>

            <h6 class="text-dark fw-bold text-uppercase mt-4">Necessary Cookies</h6>
            <p>Required for basic site functionality, such as keeping items in your shopping bag.</p>

            <h6 class="text-dark fw-bold text-uppercase mt-4">Analytical Cookies</h6>
            <p>We use Google Analytics to understand how visitors interact with the site. These cookies are anonymous.</p>

            <div class="mt-5 p-4 bg-light border">
                <p class="mb-0 fw-bold small text-dark uppercase">Manage Settings</p>
                <p class="small">By using our site, you agree to our use of cookies as described above.</p>
            </div>
        </div>
    </div>
</div>