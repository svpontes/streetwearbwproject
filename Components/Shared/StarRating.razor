<div class="d-flex align-items-center gap-1">
    @for (int i = 1; i <= 5; i++)
    {
    int starIndex = i;
    var displayRating = hoverRating != 0 ? hoverRating : Rating;

    string iconClass;

    if (starIndex <= Math.Floor(displayRating))
        iconClass = "bi-star-fill";
    else if (starIndex - displayRating <= 0.5)
        iconClass = "bi-star-half";
    else
        iconClass = "bi-star";

    <i class="bi @iconClass"
       style="cursor: @(IsReadOnly ? "default" : "pointer");
              color: @(starIndex <= displayRating ? "#FFD700" : "#ccc");
              font-size: @(Size)rem;"
       @onclick="() => HandleClick(starIndex)"
       @onmouseover="() => hoverRating = starIndex"
       @onmouseout="() => hoverRating = 0">
    </i>
    }
    @if (ShowNumber)
    {
        <span class="ms-2 small text-muted">(@Rating.ToString("0.0"))</span>
    }
</div>

@code {
    [Parameter] public double Rating { get; set; }
    [Parameter] public bool IsReadOnly { get; set; } = true;
    [Parameter] public double Size { get; set; } = 1.2;
    [Parameter] public bool ShowNumber { get; set; } = false;
    [Parameter] public EventCallback<int> OnRatingChanged { get; set; }
    private int hoverRating = 0;

    private async Task HandleClick(int newRating)
    {
        if (!IsReadOnly)
        {
            Rating = newRating;
            hoverRating = 0;
            await OnRatingChanged.InvokeAsync(newRating);
        }
    }
}