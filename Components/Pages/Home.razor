@page "/"
@rendermode InteractiveServer
@using StreetTshirtApp.Models
@using StreetTshirtApp.Components.Shared
@using System.Timers
@implements IDisposable

<PageTitle>Street T-Shirt - Official Store</PageTitle>



<section class="position-relative overflow-hidden p-0 m-0 text-center bg-dark w-100" style="height: 600px;">
    @foreach (var img in bannerImages)
    {
        <div class="banner-slide @(currentImageIndex == bannerImages.IndexOf(img) ? "active" : "")"
             style="background-image: url('@img');">
        </div>
    }

    <div class="col-md-5 p-lg-5 mx-auto my-5 position-absolute top-50 start-50 translate-middle text-white" 
         style="background-color: rgba(0,0,0,0.2); border-radius: 0; z-index: 10;">
        <h1 class="display-4 fw-bold text-uppercase" style="letter-spacing: 3px;">Urban Exclusive</h1>
        <p class="lead fw-normal mb-4">Check out our new collection of exclusive HD prints.</p>
        <a class="btn btn-light btn-lg rounded-2 fw-bold custom-bw-btn" href="#catalog">Shop the Collection</a>
    </div>
</section>

<div id="catalog" class="container mt-5 mb-5">
    <h2 class="mb-4 fw-bold text-center">Featured Designs</h2>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var product in featuredProducts)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0.5" style="background-color: #f8f9fa;">
                    
                    <a href="/product/@product.Id" class="text-decoration-none">
                        <div class="p-4 text-center">
                            <img src="@product.ImageUrl" alt="@product.Name" class="img-fluid" style="max-height: 220px; object-fit: contain;" />
                        </div>
                    </a>
                    
                    <div class="card-body d-flex flex-column text-dark">
                        <a href="/product/@product.Id" class="text-decoration-none text-dark">
                            <h5 class="card-title fw-bold">@product.Name</h5>
                        </a>
                        
                        <p class="card-text small text-muted flex-grow-1">@product.Description</p>
                        
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="fs-5 fw-bold" style="color: #747474;">$@product.Price.ToString("0.00")</span>
                            <button class="btn btn-dark btn-sm fw-bold rounded-0 px-3" @onclick="() => OpenQuickView(product)">
                                ADD to Cart
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<ProductQuickView Show="isPanelOpen" Product="selectedProduct" OnClose="HandleClose" />

@code {
    private List<Product> featuredProducts = new();
    private bool isPanelOpen = false;
    private Product? selectedProduct;

    private int currentImageIndex = 0;
    private List<string> bannerImages = new() 
    { 
        "/images/banner-principal.png", 
        "/images/bkg-banner.png" 
    };

    private Timer? timer;

    protected override void OnInitialized()
    {
        // 1. Carrega os produtos (Não esqueça desta linha!)
        featuredProducts = MockData.GetMockProducts();

        // 2. Configura o Timer do Banner
        timer = new Timer(5000);
        timer.Elapsed += (sender, e) => ChangeImage();
        timer.AutoReset = true;
        timer.Enabled = true;
    }

    private void ChangeImage()
    {
        currentImageIndex = (currentImageIndex + 1) % bannerImages.Count;
        InvokeAsync(StateHasChanged);
    }

    private void OpenQuickView(Product product)
    {
        selectedProduct = product;
        isPanelOpen = true;
        StateHasChanged();
    }

    private void HandleClose()
    {
        isPanelOpen = false;
        selectedProduct = null;
        StateHasChanged();
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}