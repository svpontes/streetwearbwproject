@page "/returns-exchanges"

<div class="container mt-5 pt-5 pb-5">
    <h1 class="fw-bold text-uppercase mb-5" style="letter-spacing: 3px;">Returns & Exchanges</h1>
    
    <div class="row">
        <div class="col-lg-8">
            <p class="lead mb-5">If you are not perfectly satisfied, you may return your items within 14 days of receipt.</p>

            <section class="mb-5">
                <h5 class="fw-bold text-uppercase">Conditions</h5>
                <ul class="text-secondary list-unstyled">
                    <li class="mb-2">/ Items must be in original condition (unworn, unwashed).</li>
                    <li class="mb-2">/ Tags and original packaging must be intact.</li>
                    <li class="mb-2">/ Return shipping costs are at the customer's expense.</li>
                </ul>
            </section>

            <section class="mb-5">
                <h5 class="fw-bold text-uppercase">How to Return</h5>
                <p class="text-secondary">Contact our support team at <strong>support@@bluntwear.com</strong> with your order number to initiate the process.</p>
            </section>
        </div>
    </div>
</div>