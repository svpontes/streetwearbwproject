@page "/admin/messages"
@using StreetTshirtApp.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

<div class="container mt-5">
    <h2 class="fw-bold text-uppercase mb-4">Contact Logs (Legal Record)</h2>

    <div class="table-responsive">
        <table class="table table-hover border">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Subject</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var msg in messages)
                {
                    <tr>
                        <td class="small">@msg.CreatedAt.ToString("g")</td>
                        <td class="fw-bold">@msg.Name</td>
                        <td>@msg.Email</td>
                        <td><span class="badge bg-secondary">@msg.Subject</span></td>
                        <td>@msg.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<ContactMessage> messages = new();

    protected override async Task OnInitializedAsync()
    {
        // Busca todas as mensagens do banco ordenadas pela mais recente
        messages = await DbContext.ContactMessages
            .OrderByDescending(m => m.CreatedAt)
            .ToListAsync();
    }
}