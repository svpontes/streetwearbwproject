@page "/admin/subscribers"
@using Microsoft.EntityFrameworkCore
@using StreetTshirtApp.Data
@using StreetTshirtApp.Models
@inject ApplicationDbContext DbContext
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Web
@using StreetTshirtApp.Services
@inject AuthService Auth
@inject NavigationManager NavManager

@* --- ADMIN NEWSLETTER MANAGEMENT ---
   Purpose: Provides a secure dashboard for administrators to monitor 
   marketing leads and manage the mailing list database.
*@

<div class="container mt-5 pt-5 pb-5">
    @* --- HEADER SECTION --- *@
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-uppercase mb-2" style="letter-spacing: 3px;">Newsletter Logs</h2>
            <p class="text-secondary small text-uppercase">Marketing Database // BluntWear</p>
        </div>
        @* Quick navigation back to the main Admin Dashboard *@
        <a href="/admin" class="btn btn-outline-dark btn-sm rounded-0 px-4 text-uppercase fw-bold">
            <i class="bi bi-arrow-left me-2"></i> Dashboard
        </a>
    </div>

    @* --- VIEW LOGIC: LOADING, EMPTY, OR DATA --- *@
    @if (subscribers == null)
    {
        @* Initial loading state while the database query is processing *@
        <div class="text-center py-5">
            <div class="spinner-border text-dark" role="status"></div>
        </div>
    }
    else if (!subscribers.Any())
    {
        @* Feedback provided when the newsletter database is currently empty *@
        <div class="alert alert-light border-dark rounded-0 text-center py-5">
            <i class="bi bi-people fs-1 d-block mb-3"></i>
            <span class="text-uppercase fw-bold">No subscribers found in the database.</span>
        </div>
    }
    else
    {
        @* --- SUBSCRIBERS TABLE --- *@
        <div class="table-responsive">
            <table class="table table-hover border">
                <thead class="table-dark text-uppercase small">
                    <tr>
                        <th class="p-3">ID</th>
                        <th class="p-3">Email Address</th>
                        <th class="p-3">Subscription Date</th>
                        <th class="p-3 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @* Iterate through the list of subscribers retrieved from the SQLite database *@
                    @foreach (var sub in subscribers)
                    {
                        <tr>
                            <td class="p-3 fw-bold">#@sub.Id</td>
                            <td class="p-3">@sub.Email</td>
                            <td class="p-3 text-secondary">@sub.SubscribedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="p-3 text-end">
                                @* Deletion trigger for cleaning up the mailing list *@
                                <button class="btn btn-sm btn-outline-danger rounded-0" 
                                        @onclick="() => DeleteSubscriber(sub.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @* Footer Metadata providing totals for administrative oversight *@
        <div class="mt-4 d-flex justify-content-between align-items-center text-secondary small">
            <span>TOTAL SUBSCRIBERS: @subscribers.Count</span>
            <span class="text-uppercase">BluntWear Proprietary Data</span>
        </div>
    }
</div>

@code {
    // Internal state holding the list of leads
    private List<NewsletterSubscriber>? subscribers;

    /// <summary>
    /// SECURITY CHECK: Ensures only users with the 'Admin' role can view this page.
    /// Standard customers are redirected to the Home page.
    /// </summary>
    protected override void OnInitialized()
    {
        if (!Auth.IsAdmin)
        {
            NavManager.NavigateTo("/");
        }
    }

    /// <summary>
    /// Lifecycle: Triggers the asynchronous database fetch once the component is ready.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadSubscribers();
    }

    /// <summary>
    /// Fetches all newsletter subscribers from the database, 
    /// sorted by the most recent subscriptions first.
    /// </summary>
    private async Task LoadSubscribers()
    {
        subscribers = await DbContext.Subscribers
            .OrderByDescending(s => s.SubscribedAt)
            .ToListAsync();
    }

    /// <summary>
    /// Removes a subscriber from the database by their unique ID.
    /// Triggers a list reload to update the UI instantly.
    /// </summary>
    /// <param name="id">The Primary Key of the subscriber record.</param>
    private async Task DeleteSubscriber(int id)
    {
        var sub = await DbContext.Subscribers.FindAsync(id);
        if (sub != null)
        {
            DbContext.Subscribers.Remove(sub);
            await DbContext.SaveChangesAsync();
            await LoadSubscribers(); // Refresh the list
        }
    }
}