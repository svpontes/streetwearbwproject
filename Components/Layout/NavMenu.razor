@using StreetTshirtApp.Services
@inject CartService CartService
@inject AuthService AuthService
@implements IDisposable

<nav class="navbar navbar-dark bg-black px-3 py-2 shadow-sm sticky-top" style="min-height: 80px;">
    <div class="container-fluid">
        <div class="row w-100 align-items-center g-0">
            
            @* Seção Esquerda: Links de Navegação *@
            <div class="col-4 d-flex align-items-center">
                <div class="d-none d-md-flex gap-3">
                    <a class="nav-link text-white fw-light small text-uppercase" href="/" style="letter-spacing: 1px;">Home</a>
                    <a class="nav-link text-white fw-light small " href="/catalog" style="letter-spacing: 1px;">Catalog</a>
                    <a class="nav-link text-white fw-light small " href="/contact" style="letter-spacing: 1px;">Contact</a>
                    
                </div>

                <button class="btn text-white d-md-none p-0 border-0" @onclick="ToggleMenu">
                    <i class="bi @(isMenuOpen ? "bi-x-lg" : "bi-list") fs-2"></i>
                </button>
            </div>

            
            <div class="col-4 text-center">
                <a class="navbar-brand d-inline-flex align-items-center m-0" href="/">
                    <img src="images/logowhite.png" alt="BW" style="height: 30px;" />
                    <span class="fw-bold d-none d-sm-inline ms-2" style="letter-spacing: 2px; font-size: 1.2rem;">BLUNTWEAR</span>
                </a>
            </div>

            @* Seção Direita: Usuário e Carrinho *@
            <div class="col-4 d-flex align-items-center justify-content-end gap-1">
                
                @if (AuthService.CurrentUser == null)
                {
                    @* Ícone de Login (Caso não esteja logado) *@
                    <a href="/login" class="text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; text-decoration: none;">
                        <i class="bi bi-person" style="font-size: 2rem;"></i>
                    </a>
                }
                else
                {
                    @* Dropdown do Usuário (Caso esteja logado) *@
                    <div class="dropdown">
                        <button class="btn text-white fw-bold small text-uppercase dropdown-toggle border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-check-fill me-1"></i> @AuthService.CurrentUser.Name.Split(' ')[0]
                        </button>
                        <ul class="dropdown-menu dropdown-menu-dark rounded-0 border-secondary shadow">
                            <li><a class="dropdown-item small py-2" href="/profile">MY PROFILE</a></li>
                            <li><hr class="dropdown-divider border-secondary"></li>
                            <li><button class="dropdown-item small py-2 text-danger" @onclick="Logout">LOGOUT</button></li>
                        </ul>
                    </div>
                }
                
                @* Ícone do Carrinho *@
                <a href="/cart" class="text-white position-relative d-flex align-items-center justify-content-center" 
                   style="width: 50px; height: 50px; text-decoration: none; overflow: visible;">
                    
                    <i class="bi bi-bag" style="font-size: 2rem; z-index: 1;"></i>
                    
                    @if (CartService.TotalItems > 0)
                    {
                        <span class="position-absolute d-flex align-items-center justify-content-center fw-bold" 
                              style="top: 22px; 
                                     left: 26px; 
                                     width: 18px; 
                                     height: 18px; 
                                     background-color: white; 
                                     color: black; 
                                     border-radius: 50%; 
                                     font-size: 0.65rem; 
                                     z-index: 2;
                                     box-shadow: 0 0 5px rgba(0,0,0,0.5);
                                     line-height: 1;
                                     pointer-events: none;">
                            @CartService.TotalItems
                        </span>
                    }
                </a>
            </div>
        </div>
    </div>

    @* Menu Mobile *@
    <div class="collapse @(isMenuOpen ? "show" : "") d-md-none w-100 bg-dark mt-2 border-top border-secondary">
        <div class="d-flex flex-column p-4 gap-3 text-center">
            <a class="nav-link text-white fw-bold fs-5 text-uppercase" href="/" @onclick="ToggleMenu">Home</a>
            <a class="nav-link text-white fw-bold fs-5 text-uppercase" href="/catalog" @onclick="ToggleMenu">Catalog</a>
            <hr class="text-secondary" />
            @if (AuthService.CurrentUser == null)
            {
                <a class="nav-link text-secondary small" href="/login" @onclick="ToggleMenu">LOGIN / REGISTER</a>
            }
            else
            {
                <a class="nav-link text-white small" href="/profile" @onclick="ToggleMenu">MY ACCOUNT (@AuthService.CurrentUser.Name)</a>
                <button class="btn btn-link text-danger small text-decoration-none" @onclick="Logout">LOGOUT</button>
            }
        </div>
    </div>
    
</nav>

@code {
    private bool isMenuOpen = false;

    private void ToggleMenu() => isMenuOpen = !isMenuOpen;

    protected override void OnInitialized()
    {
        // Inscreve nos dois serviços para atualizar a UI em tempo real
        CartService.OnChange += HandleChange;
        AuthService.OnChange += HandleChange;
    }

    private async void HandleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        AuthService.Logout();
        isMenuOpen = false;
       // NavManager.NavigateTo("/");
    }

    public void Dispose()
    {
        CartService.OnChange -= HandleChange;
        AuthService.OnChange -= HandleChange;
    }
}