@page "/order-success"
@inject NavigationManager NavManager

<div class="container mt-5 pt-5 pb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill display-1 text-dark"></i>
            </div>

            <h1 class="fw-bold text-uppercase mb-3" style="letter-spacing: 4px;">Order Confirmed</h1>
            
            <p class="text-secondary mb-5">
                Your order has been placed successfully. <br />
                We've sent a confirmation email with all the details and tracking information.
            </p>

            <div class="card border-1 rounded-0 bg-light p-4 mb-5 text-start">
                <h6 class="fw-bold text-uppercase mb-3">What's Next?</h6>
                <ul class="list-unstyled mb-0 small text-secondary">
                    <li class="mb-2"><i class="bi bi-envelope me-2"></i> Check your inbox for the receipt.</li>
                    <li class="mb-2"><i class="bi bi-truck me-2"></i> We'll notify you when your drop ships.</li>
                    <li><i class="bi bi-star me-2"></i> Tag us on social media for a chance to be featured.</li>
                </ul>
            </div>

            <div class="d-grid gap-2">
                <button @onclick="GoToCatalog" class="btn btn-dark py-3 fw-bold text-uppercase rounded-0">
                    Continue Shopping
                </button>
                <button @onclick="GoToHome" class="btn btn-outline-dark py-2 fw-bold text-uppercase rounded-0 border-2">
                    Back to Home
                </button>
            </div>
            
            <p class="mt-5 text-muted x-small">Order ID: #@GenerateOrderNumber()</p>
        </div>
    </div>
</div>

@code {
    private void GoToCatalog() => NavManager.NavigateTo("/catalog");
    private void GoToHome() => NavManager.NavigateTo("/");

    // Apenas para efeito visual, já que o carrinho foi limpo
    private string GenerateOrderNumber()
    {
        return Random.Shared.Next(100000, 999999).ToString();
    }
}

<style>
    .x-small {
        font-size: 0.75rem;
        letter-spacing: 1px;
    }
    
    .container {
        animation: fadeIn 0.8s ease-in-out;
    }

    /* Use @@ para fazer o escape do símbolo no Blazor */
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>