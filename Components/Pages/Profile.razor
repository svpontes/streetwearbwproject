@page "/profile"
@using StreetTshirtApp.Models
@using Microsoft.EntityFrameworkCore
@inject StreetTshirtApp.Services.AuthService AuthService
@inject StreetTshirtApp.Data.ApplicationDbContext DbContext
@inject NavigationManager NavManager

@* --- INTERACTIVE ACCOUNT PROFILE PAGE ---
    Purpose: Allows users to view and update their personal/shipping information.
    Changes are persisted to the database via ProductService.
*@

<PageTitle>My Profile - BluntWear</PageTitle>

@if (AuthService.CurrentUser == null)
{
    <div class="container text-center mt-5 py-5">
        <i class="bi bi-lock display-1 text-muted"></i>
        <p class="lead mt-3">Please login to view your profile.</p>
        <a href="/login" class="btn btn-dark rounded-0 px-5 fw-bold">GO TO LOGIN</a>
    </div>
}
else
{
    <div class="container mt-5 mb-5">
        <div class="row">
            
            @* --- LEFT COLUMN: EDITABLE PROFILE FORM --- *@
            <div class="col-md-4 mb-4">
                <div class="card bg-white text-dark rounded-0 border p-4 shadow-sm">
                    <div class="text-center mb-4">
                        <i class="bi bi-person-circle display-1"></i>
                        <h3 class="fw-bold mt-2 text-uppercase" style="letter-spacing: 2px;">My Account</h3>
                    </div>

                    <EditForm Model="AuthService.CurrentUser" OnValidSubmit="HandleUpdate">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="fw-bold text-secondary text-uppercase x-small">Full Name</label>
                            <InputText @bind-Value="AuthService.CurrentUser.Name" class="form-control form-control-sm rounded-0 border-dark" />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold text-secondary text-uppercase x-small">Email (Read-only)</label>
                            <input type="text" value="@AuthService.CurrentUser.Email" class="form-control form-control-sm rounded-0 bg-light" disabled />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold text-secondary text-uppercase x-small">Phone</label>
                            <InputText @bind-Value="AuthService.CurrentUser.Phone" class="form-control form-control-sm rounded-0 border-dark" placeholder="Enter phone" />
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold text-secondary text-uppercase x-small">Shipping Address</label>
                            <InputText @bind-Value="AuthService.CurrentUser.Address" class="form-control form-control-sm rounded-0 border-dark" placeholder="Street name and number" />
                        </div>

                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="fw-bold text-secondary text-uppercase x-small">City</label>
                                <InputText @bind-Value="AuthService.CurrentUser.City" class="form-control form-control-sm rounded-0 border-dark" />
                            </div>
                            <div class="col-6">
                                <label class="fw-bold text-secondary text-uppercase x-small">Zip Code</label>
                                <InputText @bind-Value="AuthService.CurrentUser.ZipCode" class="form-control form-control-sm rounded-0 border-dark" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold text-secondary text-uppercase x-small">Country</label>
                            <InputText @bind-Value="AuthService.CurrentUser.Country" class="form-control form-control-sm rounded-0 border-dark" />
                        </div>

                        <button type="submit" class="btn btn-dark btn-sm w-100 rounded-0 fw-bold mb-2 py-2">
                            @(isSaving ? "SAVING..." : "UPDATE PROFILE")
                        </button>
                    </EditForm>

                    <button class="btn btn-outline-danger btn-sm w-100 rounded-0 fw-bold py-2" @onclick="Logout">LOGOUT</button>
                    
                    @if (!string.IsNullOrEmpty(statusMessage))
                    {
                        <div class="alert alert-success mt-3 rounded-0 small p-2 text-center">@statusMessage</div>
                    }
                </div>
            </div>

            @* --- RIGHT COLUMN: ORDER HISTORY --- *@
            <div class="col-md-8">
                <h2 class="fw-bold mb-4 text-uppercase" style="letter-spacing: 2px;">Order History</h2>
                @* ... (Mantenha aqui o código do histórico de pedidos que enviamos antes) ... *@
            </div>
        </div>
    </div>
}

<style>
    .x-small { font-size: 0.65rem; letter-spacing: 1px; }
    .form-control:focus { border-color: #CCFF00; box-shadow: none; }
</style>

@code {
    private bool isSaving = false;
    private string statusMessage = "";

    /// <summary>
    /// Persists the updated user information to the SQLite database.
    /// </summary>
    private async Task HandleUpdate()
{
    isSaving = true;
    statusMessage = "";

    try 
    {
        if (AuthService.CurrentUser != null)
        {
            // 1. Verificamos se já existe uma instância do mesmo utilizador sendo rastreada
            var trackedUser = DbContext.Users.Local.FirstOrDefault(u => u.Id == AuthService.CurrentUser.Id);
            
            if (trackedUser != null)
            {
                // Se existir, "desvinculamos" a instância antiga da memória temporária (Detach)
                DbContext.Entry(trackedUser).State = EntityState.Detached;
            }

            // 2. Agora anexamos a versão atualizada do AuthService.CurrentUser
            DbContext.Users.Update(AuthService.CurrentUser);
            
            // 3. Persistimos no SQLite
            await DbContext.SaveChangesAsync();

            statusMessage = "Profile updated successfully!";
        }
    }
    catch (Exception ex)
    {
        statusMessage = "Database Error: " + ex.Message;
        // Opcional: Console.WriteLine(ex.ToString()); para debugar
    }
    finally
    {
        isSaving = false;
    }
    }

    private void Logout()
    {
        AuthService.Logout();
        NavManager.NavigateTo("/", forceLoad: true);
    }
}