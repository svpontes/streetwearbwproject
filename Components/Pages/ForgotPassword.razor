@page "/forgot-password"
@using Microsoft.EntityFrameworkCore
@using StreetTshirtApp.Data
@inject ApplicationDbContext DbContext
@inject NavigationManager NavManager

@* --- FORGOT PASSWORD PAGE ---
   Purpose: Validates if an email exists in the SQLite database and 
   provides feedback for the recovery process.
*@

<div class="row justify-content-center align-items-center min-vh-100" style="margin-top: -100px;">
    <div class="col-md-5">
        <div class="card border-0 shadow-lg p-4 bg-black text-white rounded-0">
            <h2 class="text-center fw-bold mb-4" style="letter-spacing: 2px;">RECOVER ACCESS</h2>
            
            <div class="mb-4">
                <label class="small fw-bold text-secondary">EMAIL ADDRESS</label>
                <input type="email" @bind="email" class="form-control bg-transparent border-secondary text-white rounded-0 py-2" placeholder="email@example.com" />
            </div>

            @* STATUS MESSAGE AREA *@
            @if (!string.IsNullOrEmpty(statusMessage))
            {
                @* The border and text color change based on the isError boolean *@
                <div class="alert bg-transparent border-@(isError ? "danger" : "success") text-@(isError ? "danger" : "lime") small rounded-0 mb-3">
                    @statusMessage
                </div>
            }

            <button class="btn btn-light w-100 fw-bold py-2 mb-3" @onclick="HandleRecovery" disabled="@isProcessing">
                @(isProcessing ? "PROCESSING..." : "RESET PASSWORD")
            </button>

            <div class="text-center">
                <a href="/login" class="text-secondary small text-decoration-none hover-lime">BACK TO LOGIN</a>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string statusMessage = "";
    private bool isError = false;
    private bool isProcessing = false;

    /// <summary>
    /// Business Logic: Verifies the email in the database and triggers the UI feedback.
    /// </summary>
    private async Task HandleRecovery()
    {
        // 1. Basic validation: Check if field is empty
        if (string.IsNullOrEmpty(email)) {
            statusMessage = "Please enter your email.";
            isError = true;
            return;
        }

        // 2. Format validation: Simple check for @ and dot
        if (!email.Contains("@") || !email.Contains(".")) {
            statusMessage = "Invalid email format. Please check.";
            isError = true;
            return;
        }

        isProcessing = true;
        isError = false;

        try 
        {
            // 3. Database lookup: Search for the user in SQLite
            var user = await DbContext.Users.FirstOrDefaultAsync(u => u.Email == email);
            
            // Artificial delay to show the "Processing" state on the button
            await Task.Delay(1000); 

            if (user != null)
            {
                // CASE: Email found
                statusMessage = "Recovery instructions sent! Check your inbox.";
                isError = false;
                // In a real scenario, you would call an EmailService here
            }
            else
            {
                // CASE: Email not registered
                statusMessage = "This email is not registered. Please check the typing.";
                isError = true;
            }
        }
        catch (Exception ex)
        {
            statusMessage = "System error: " + ex.Message;
            isError = true;
        }
        finally
        {
            isProcessing = false;
        }
    }
}

<style>
    /* Styling for the lime green hover effect */
    .hover-lime:hover {
        color: #CCFF00 !important;
        transition: 0.3s;
    }
    
    .text-lime {
        color: #CCFF00 !important;
    }
</style>