@using StreetTshirtApp.Services
@inject CartService CartService
@inject AuthService AuthService
@inject NavigationManager NavManager
@implements IDisposable

<nav class="navbar navbar-dark bg-black px-3 py-2 shadow-sm sticky-top" style="min-height: 80px;">
    <div class="container-fluid">
        <div class="row w-100 align-items-center g-0">
            
            <div class="col-4 d-flex align-items-center">
                <div class="d-none d-md-flex gap-3">
                    <a class="nav-link text-white fw-light small text-uppercase" href="/">Home</a>
                    <a class="nav-link text-white fw-light small" href="/catalog">Catalog</a>
                    <a class="nav-link text-white fw-light small" href="/contact">Contact</a>
                </div>

                <button class="btn text-white d-md-none p-0 border-0" @onclick="ToggleMenu">
                    <i class="bi @(isMenuOpen ? "bi-x-lg" : "bi-list") fs-2"></i>
                </button>
            </div>

            <div class="col-4 text-center">
                <a class="navbar-brand d-inline-flex align-items-center m-0" href="/">
                    <img src="images/logowhite.png" alt="BW" style="height: 30px;" />
                    <span class="fw-bold d-none d-sm-inline ms-2" style="letter-spacing: 2px;">BLUNTWEAR</span>
                </a>
            </div>

            <div class="col-4 d-flex align-items-center justify-content-end gap-1">
                @if (AuthService.CurrentUser == null)
                {
                    <a href="/login" class="text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; text-decoration: none;">
                        <i class="bi bi-person" style="font-size: 2rem;"></i>
                    </a>
                }
                else
                {
                    <div class="dropdown">
                        <button class="btn text-white fw-bold text-uppercase dropdown-toggle border-0 d-flex align-items-center"
                                type="button"
                                id="userMenu"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                style="letter-spacing: 1px;">
                            <i class="bi bi-person-check-fill me-2 fs-5"></i>
                            @AuthService.CurrentUser.Name.Split(' ')[0]
                        </button>

                        <ul class="dropdown-menu dropdown-menu-dark rounded-0 border-0 shadow-lg dropdown-menu-end custom-dropdown-bg" aria-labelledby="userMenu">
                            @if (AuthService.IsAdmin)
                            {
                                <li><a class="dropdown-item py-3 fw-bold text-uppercase text-warning" href="/admin">Admin Panel</a></li>
                            }
                            <li><a class="dropdown-item py-3 fw-bold text-uppercase" href="/profile">My Profile</a></li>
                            <li><button class="dropdown-item py-3 fw-bold text-uppercase text-danger" @onclick="Logout">Logout</button></li>
                        </ul>
                    </div>
                }

                <a href="/cart" class="text-white position-relative d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; text-decoration: none;">
                    <i class="bi bi-bag" style="font-size: 2rem;"></i>
                    @if (CartService.TotalItems > 0)
                    {
                        <span class="position-absolute d-flex align-items-center justify-content-center fw-bold"
                              style="top: 22px; left: 26px; width: 18px; height: 18px; background-color: white; color: black; border-radius: 50%; font-size: 0.65rem; z-index: 2;">
                            @CartService.TotalItems
                        </span>
                    }
                </a>
            </div>
        </div>
    </div>

    <div class="collapse @(isMenuOpen ? "show" : "") d-md-none w-100 bg-dark mt-2 border-top border-secondary">
        <div class="d-flex flex-column p-4 gap-3 text-center text-white">
            <a class="nav-link text-white fw-bold fs-5 text-uppercase" href="/" @onclick="ToggleMenu">Home</a>
            <a class="nav-link text-white fw-bold fs-5 text-uppercase" href="/catalog" @onclick="ToggleMenu">Catalog</a>
            @if (AuthService.IsAdmin)
            {
                <a class="nav-link text-warning fw-bold fs-5 text-uppercase" href="/admin" @onclick="ToggleMenu">ADMIN PANEL</a>
            }
            <hr class="border-secondary" />
            <a class="nav-link text-white fw-bold text-uppercase" href="/profile" @onclick="ToggleMenu">PROFILE</a>
            <button class="btn btn-link text-danger fw-bold text-uppercase text-decoration-none" @onclick="Logout">LOGOUT</button>
        </div>
    </div>
</nav>

<style>
    #userMenu:focus,
    #userMenu:active,
    #userMenu.show {
        outline: none !important;
        box-shadow: none !important;
        border: none !important;
        background-color: transparent !important;
    }

    .custom-dropdown-bg {
        background-color: #000000 !important;
        min-width: 200px;
        padding: 0;
        margin-top: 10px !important;
        border-radius: 0 !important;
        border: 1px solid #1a1a1a !important;
        right: 0 !important;
        left: auto !important;
    }

    .custom-dropdown-bg .dropdown-item {
        color: #ffffff !important;
        font-size: 0.9rem;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 15px 20px;
        transition: background 0.2s;
        border-bottom: 1px solid #1a1a1a;
        text-align: right !important;
    }

    .custom-dropdown-bg .dropdown-item:hover {
        background-color: #1a1a1a !important;
        color: white !important;
    }

    .custom-dropdown-bg button.dropdown-item {
        width: 100%;
        text-align: right !important;
        background: none;
        border-left: none;
        border-right: none;
        border-top: none;
    }

    .dropdown-menu {
        z-index: 2000 !important;
    }

    .navbar {
        overflow: visible !important;
    }
</style>

@code {
    private bool isMenuOpen = false;

    private void ToggleMenu() => isMenuOpen = !isMenuOpen;

    protected override void OnInitialized()
    {
        CartService.OnChange += HandleChange;
        AuthService.OnChange += HandleChange;
    }

    private async void HandleChange()
    {
        await InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        AuthService.Logout();
        isMenuOpen = false;
        NavManager.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        CartService.OnChange -= HandleChange;
        AuthService.OnChange -= HandleChange;
    }
}